{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "//": "The service worker must never be served stale, or the iPad will keep running an old copy of the app forever.",
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "//": "Same for the shell and the bundle: the SW does the offline caching, so HTTP caching here only causes stale-app bugs.",
      "source": "/(index.html|app.js|manifest.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "//": "Fonts are content-hashed, so they can be cached forever.",
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
